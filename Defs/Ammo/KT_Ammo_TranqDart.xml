<?xml version="1.0" encoding="utf-8"?>
<Defs>

  <ThingCategoryDef>
    <defName>AmmoKT_TranqDart</defName>
    <label>KT Tranq Dart</label>
    <parent>AmmoAdvanced</parent>
    <iconPath>UI/Icons/ThingCategories/CaliberCharge</iconPath>
  </ThingCategoryDef>

  <!-- ==================== AmmoSet ========================== -->

  <CombatExtended.AmmoSetDef>
    <defName>AmmoSet_KT_TranqDart</defName>
    <label>KT Tranq Dart</label>
    <ammoTypes>
      <Ammo_KT_TranqDart>Bullet_KT_TranqDart</Ammo_KT_TranqDart>
    </ammoTypes>
  </CombatExtended.AmmoSetDef>

  <!-- ==================== Ammo ========================== -->

  <ThingDef Class="CombatExtended.AmmoDef" ParentName="SpacerSmallAmmoBase">
    <defName>Ammo_KT_TranqDart</defName>
    <label>KT tranq dart</label>
    <description>Precision tranquilizer dart for the KT sedation rifle. Delivers a fast-acting sedative compound on impact.</description>
    <graphicData>
      <texPath>Things/Ammo/Needle/Standard</texPath>
      <graphicClass>Graphic_StackCount</graphicClass>
    </graphicData>
    <statBases>
      <Mass>0.01</Mass>
      <Bulk>0.02</Bulk>
    </statBases>
    <tradeTags>
      <li>CE_AutoEnableTrade</li>
      <li>CE_AutoEnableCrafting_FabricationBench</li>
    </tradeTags>
    <thingCategories>
      <li>AmmoKT_TranqDart</li>
    </thingCategories>
    <stackLimit>500</stackLimit>
    <ammoClass>KT_TranqDart</ammoClass>
  </ThingDef>

  <!-- ================== Projectiles ================== -->

  <ThingDef ParentName="BaseBulletCE">
    <defName>Bullet_KT_TranqDart</defName>
    <label>KT tranq dart</label>
    <graphicData>
      <texPath>Things/Projectile/Bullet_Tranquilizer</texPath>
      <graphicClass>Graphic_Single</graphicClass>
      <drawSize>(0.5,0.5)</drawSize>
    </graphicData>
    <projectile Class="CombatExtended.ProjectilePropertiesCE">
      <damageDef>BulletTranquilizer</damageDef>
      <damageAmountBase>2</damageAmountBase>
      <speed>100</speed>
      <armorPenetrationSharp>5</armorPenetrationSharp>
      <armorPenetrationBlunt>1</armorPenetrationBlunt>
      <stoppingPower>5</stoppingPower>
    </projectile>
  </ThingDef>

  <!-- ==================== Recipes ========================== -->

  <RecipeDef ParentName="AmmoRecipeBase">
    <defName>MakeAmmo_KT_TranqDart</defName>
    <label>make KT tranq dart x100</label>
    <description>Craft 100 KT tranquilizer darts.</description>
    <jobString>Making KT tranq darts.</jobString>
    <ingredients>
      <li>
        <filter>
          <thingDefs><li>Steel</li></thingDefs>
        </filter>
        <count>10</count>
      </li>
      <li>
        <filter>
          <thingDefs><li>MedicineHerbal</li></thingDefs>
        </filter>
        <count>5</count>
      </li>
    </ingredients>
    <fixedIngredientFilter>
      <thingDefs>
        <li>Steel</li>
        <li>MedicineHerbal</li>
      </thingDefs>
    </fixedIngredientFilter>
    <products>
      <Ammo_KT_TranqDart>100</Ammo_KT_TranqDart>
    </products>
    <workAmount>6000</workAmount>
  </RecipeDef>

</Defs>
