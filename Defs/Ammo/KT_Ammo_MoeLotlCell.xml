<?xml version="1.0" encoding="utf-8"?>
<Defs>

  <ThingCategoryDef>
    <defName>AmmoKT_MoeLotlCell</defName>
    <label>KT MoeLotl Cell</label>
    <parent>AmmoAdvanced</parent>
    <iconPath>UI/Icons/ThingCategories/CaliberCharge</iconPath>
  </ThingCategoryDef>

  <!-- ==================== AmmoSet ========================== -->

  <CombatExtended.AmmoSetDef>
    <defName>AmmoSet_KT_MoeLotlCell</defName>
    <label>KT MoeLotl Cell</label>
    <ammoTypes>
      <Ammo_KT_MoeLotlCell>Bullet_KT_MoeLotlCell</Ammo_KT_MoeLotlCell>
      <Ammo_KT_MoeLotlCell_Focused>Bullet_KT_MoeLotlCell_Focused</Ammo_KT_MoeLotlCell_Focused>
    </ammoTypes>
  </CombatExtended.AmmoSetDef>

  <!-- ==================== Ammo ========================== -->

  <ThingDef Class="CombatExtended.AmmoDef" Name="KT_MoeLotlCellBase" ParentName="SpacerSmallAmmoBase" Abstract="True">
    <description>Compact energy cell for UF Heavy Industries MoeLotl gatling weapons.</description>
    <statBases>
      <Mass>0.01</Mass>
      <Bulk>0.02</Bulk>
    </statBases>
    <tradeTags>
      <li>CE_AutoEnableTrade</li>
      <li>CE_AutoEnableCrafting_FabricationBench</li>
    </tradeTags>
    <thingCategories>
      <li>AmmoKT_MoeLotlCell</li>
    </thingCategories>
    <stackLimit>5000</stackLimit>
  </ThingDef>

  <ThingDef Class="CombatExtended.AmmoDef" ParentName="KT_MoeLotlCellBase">
    <defName>Ammo_KT_MoeLotlCell</defName>
    <label>KT MoeLotl cell</label>
    <graphicData>
      <texPath>Things/Ammo/Charged/SmallRegular</texPath>
      <graphicClass>Graphic_StackCount</graphicClass>
    </graphicData>
    <ammoClass>KT_Laser</ammoClass>
  </ThingDef>

  <ThingDef Class="CombatExtended.AmmoDef" ParentName="KT_MoeLotlCellBase">
    <defName>Ammo_KT_MoeLotlCell_Focused</defName>
    <label>KT MoeLotl cell (Focused)</label>
    <graphicData>
      <texPath>Things/Ammo/Charged/SmallConc</texPath>
      <graphicClass>Graphic_StackCount</graphicClass>
    </graphicData>
    <ammoClass>KT_LaserFocused</ammoClass>
    <generateAllowChance>0.15</generateAllowChance>
  </ThingDef>

  <!-- ================== Projectiles ================== -->

  <ThingDef Name="BaseKT_MoeLotlCellBullet" ParentName="BaseBulletCE" Abstract="true">
    <graphicData>
      <texPath>Things/Projectile/Charged/ChargeShot</texPath>
      <graphicClass>Graphic_Single</graphicClass>
      <shaderType>TransparentPostLight</shaderType>
    </graphicData>
    <projectile Class="CombatExtended.ProjectilePropertiesCE">
      <damageDef>Bullet</damageDef>
    </projectile>
  </ThingDef>

  <ThingDef ParentName="BaseKT_MoeLotlCellBullet">
    <defName>Bullet_KT_MoeLotlCell</defName>
    <label>KT MoeLotl bolt</label>
    <projectile Class="CombatExtended.ProjectilePropertiesCE">
      <damageAmountBase>18</damageAmountBase>
      <speed>155</speed>
      <armorPenetrationSharp>45</armorPenetrationSharp>
      <armorPenetrationBlunt>120</armorPenetrationBlunt>
    </projectile>
  </ThingDef>

  <ThingDef ParentName="BaseKT_MoeLotlCellBullet">
    <defName>Bullet_KT_MoeLotlCell_Focused</defName>
    <label>KT MoeLotl bolt (Focused)</label>
    <projectile Class="CombatExtended.ProjectilePropertiesCE">
      <damageAmountBase>14</damageAmountBase>
      <speed>165</speed>
      <armorPenetrationSharp>85</armorPenetrationSharp>
      <armorPenetrationBlunt>120</armorPenetrationBlunt>
    </projectile>
  </ThingDef>

  <!-- ==================== Recipes ========================== -->

  <RecipeDef ParentName="ChargeAmmoRecipeBase">
    <defName>MakeAmmo_KT_MoeLotlCell</defName>
    <label>make KT MoeLotl cell x500</label>
    <description>Craft 500 KT MoeLotl cells.</description>
    <jobString>Making KT MoeLotl cells.</jobString>
    <ingredients>
      <li>
        <filter>
          <thingDefs><li>Plasteel</li></thingDefs>
        </filter>
        <count>15</count>
      </li>
      <li>
        <filter>
          <thingDefs><li>Steel</li></thingDefs>
        </filter>
        <count>10</count>
      </li>
      <li>
        <filter>
          <thingDefs><li>ComponentIndustrial</li></thingDefs>
        </filter>
        <count>3</count>
      </li>
    </ingredients>
    <fixedIngredientFilter>
      <thingDefs>
        <li>Plasteel</li>
        <li>Steel</li>
        <li>ComponentIndustrial</li>
      </thingDefs>
    </fixedIngredientFilter>
    <products>
      <Ammo_KT_MoeLotlCell>500</Ammo_KT_MoeLotlCell>
    </products>
    <workAmount>6000</workAmount>
  </RecipeDef>

  <RecipeDef ParentName="ChargeAmmoRecipeBase">
    <defName>MakeAmmo_KT_MoeLotlCell_Focused</defName>
    <label>make KT MoeLotl cell (Focused) x500</label>
    <description>Craft 500 KT MoeLotl cells (Focused).</description>
    <jobString>Making KT MoeLotl cells (Focused).</jobString>
    <ingredients>
      <li>
        <filter>
          <thingDefs><li>Plasteel</li></thingDefs>
        </filter>
        <count>15</count>
      </li>
      <li>
        <filter>
          <thingDefs><li>Steel</li></thingDefs>
        </filter>
        <count>10</count>
      </li>
      <li>
        <filter>
          <thingDefs><li>ComponentIndustrial</li></thingDefs>
        </filter>
        <count>4</count>
      </li>
    </ingredients>
    <fixedIngredientFilter>
      <thingDefs>
        <li>Plasteel</li>
        <li>Steel</li>
        <li>ComponentIndustrial</li>
      </thingDefs>
    </fixedIngredientFilter>
    <products>
      <Ammo_KT_MoeLotlCell_Focused>500</Ammo_KT_MoeLotlCell_Focused>
    </products>
    <workAmount>7000</workAmount>
  </RecipeDef>

</Defs>
