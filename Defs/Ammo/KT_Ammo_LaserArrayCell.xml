<?xml version="1.0" encoding="utf-8"?>
<Defs>

  <ThingCategoryDef>
    <defName>AmmoKT_LaserArrayCell</defName>
    <label>KT Laser Array Cell</label>
    <parent>AmmoAdvanced</parent>
    <iconPath>UI/Icons/ThingCategories/CaliberCharge</iconPath>
  </ThingCategoryDef>

  <!-- ==================== AmmoSet ========================== -->

  <CombatExtended.AmmoSetDef>
    <defName>AmmoSet_KT_LaserArrayCell</defName>
    <label>KT Laser Array Cell</label>
    <ammoTypes>
      <Ammo_KT_LaserArrayCell>Bullet_KT_LaserArrayCell</Ammo_KT_LaserArrayCell>
    </ammoTypes>
  </CombatExtended.AmmoSetDef>

  <!-- ==================== Ammo ========================== -->

  <ThingDef Class="CombatExtended.AmmoDef" ParentName="SpacerSmallAmmoBase">
    <defName>Ammo_KT_LaserArrayCell</defName>
    <label>KT laser array cell</label>
    <description>Compact energy cell for UF Heavy Industries laser array weapons. Fires a burst of scatter laser bolts.</description>
    <graphicData>
      <texPath>Things/Ammo/Charged/SmallRegular</texPath>
      <graphicClass>Graphic_StackCount</graphicClass>
    </graphicData>
    <statBases>
      <Mass>0.02</Mass>
      <Bulk>0.03</Bulk>
    </statBases>
    <ammoClass>KT_Laser</ammoClass>
    <tradeTags>
      <li>CE_AutoEnableTrade</li>
      <li>CE_AutoEnableCrafting_FabricationBench</li>
    </tradeTags>
    <thingCategories>
      <li>AmmoKT_LaserArrayCell</li>
    </thingCategories>
    <stackLimit>5000</stackLimit>
  </ThingDef>

  <!-- ================== Projectiles ================== -->

  <ThingDef ParentName="BaseBulletCE">
    <defName>Bullet_KT_LaserArrayCell</defName>
    <label>KT laser array bolt</label>
    <thingClass>UFHeavyIndustries_CE.BulletCE_WithBeam</thingClass>
    <graphicData>
      <texPath>Things/Projectile/Charged/ChargeShot</texPath>
      <graphicClass>Graphic_Single</graphicClass>
      <shaderType>TransparentPostLight</shaderType>
    </graphicData>
    <projectile Class="CombatExtended.ProjectilePropertiesCE">
      <damageDef>Bullet</damageDef>
      <damageAmountBase>22</damageAmountBase>
      <speed>130</speed>
      <pelletCount>8</pelletCount>
      <spreadMult>10</spreadMult>
      <armorPenetrationSharp>45</armorPenetrationSharp>
      <armorPenetrationBlunt>150</armorPenetrationBlunt>
    </projectile>
    <modExtensions>
      <li Class="UFHeavyIndustries_CE.BeamVisualExtension">
        <beamMoteDef>KT_Beamflashlight</beamMoteDef>
        <impactEffecter>KT_Laserhit</impactEffecter>
      </li>
    </modExtensions>
  </ThingDef>

  <!-- ==================== Recipes ========================== -->

  <RecipeDef ParentName="ChargeAmmoRecipeBase">
    <defName>MakeAmmo_KT_LaserArrayCell</defName>
    <label>make KT laser array cell x500</label>
    <description>Craft 500 KT laser array cells.</description>
    <jobString>Making KT laser array cells.</jobString>
    <ingredients>
      <li>
        <filter>
          <thingDefs><li>Plasteel</li></thingDefs>
        </filter>
        <count>25</count>
      </li>
      <li>
        <filter>
          <thingDefs><li>Steel</li></thingDefs>
        </filter>
        <count>15</count>
      </li>
      <li>
        <filter>
          <thingDefs><li>ComponentIndustrial</li></thingDefs>
        </filter>
        <count>6</count>
      </li>
    </ingredients>
    <fixedIngredientFilter>
      <thingDefs>
        <li>Plasteel</li>
        <li>Steel</li>
        <li>ComponentIndustrial</li>
      </thingDefs>
    </fixedIngredientFilter>
    <products>
      <Ammo_KT_LaserArrayCell>500</Ammo_KT_LaserArrayCell>
    </products>
    <workAmount>10000</workAmount>
  </RecipeDef>

</Defs>
