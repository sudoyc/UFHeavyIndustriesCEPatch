  <RecipeDef ParentName="ChargeAmmoRecipeBase">
    <defName>MakeAmmo_KT_BoltRound_Incendiary</defName>
    <label>make KT bolt round (Incendiary) x200</label>
    <description>Craft 200 KT bolt rounds (Incendiary).</description>
    <jobString>Making KT bolt rounds (Incendiary).</jobString>
    <ingredients>
      <li>
        <filter>
          <thingDefs><li>Plasteel</li></thingDefs>
        </filter>
        <count>35</count>
      </li>
      <li>
        <filter>
          <thingDefs><li>Steel</li></thingDefs>
        </filter>
        <count>30</count>
      </li>
      <li>
        <filter>
          <thingDefs><li>Chemfuel</li></thingDefs>
        </filter>
        <count>25</count>
      </li>
      <li>
        <filter>
          <thingDefs><li>ComponentIndustrial</li></thingDefs>
        </filter>
        <count>8</count>
