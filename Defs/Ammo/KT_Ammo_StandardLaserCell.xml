<?xml version="1.0" encoding="utf-8"?>
<Defs>

  <ThingCategoryDef>
    <defName>AmmoKT_StandardLaserCell</defName>
    <label>KT Standard Laser Cell</label>
    <parent>AmmoAdvanced</parent>
    <iconPath>UI/Icons/ThingCategories/CaliberCharge</iconPath>
  </ThingCategoryDef>

  <!-- ==================== AmmoSet ========================== -->

  <CombatExtended.AmmoSetDef>
    <defName>AmmoSet_KT_StandardLaserCell</defName>
    <label>KT Standard Laser Cell</label>
    <ammoTypes>
      <Ammo_KT_StandardLaserCell>Bullet_KT_StandardLaserCell</Ammo_KT_StandardLaserCell>
      <Ammo_KT_StandardLaserCell_Focused>Bullet_KT_StandardLaserCell_Focused</Ammo_KT_StandardLaserCell_Focused>
      <Ammo_KT_StandardLaserCell_Pulse>Bullet_KT_StandardLaserCell_Pulse</Ammo_KT_StandardLaserCell_Pulse>
    </ammoTypes>
  </CombatExtended.AmmoSetDef>

  <!-- ==================== Ammo ========================== -->

  <ThingDef Class="CombatExtended.AmmoDef" Name="KT_StandardLaserCellBase" ParentName="SpacerSmallAmmoBase" Abstract="True">
    <description>Compact energy cell for UF covenant standard laser weapons.</description>
    <statBases>
      <Mass>0.02</Mass>
      <Bulk>0.04</Bulk>
    </statBases>
    <tradeTags>
      <li>CE_AutoEnableTrade</li>
      <li>CE_AutoEnableCrafting_FabricationBench</li>
    </tradeTags>
    <thingCategories>
      <li>AmmoKT_StandardLaserCell</li>
    </thingCategories>
    <stackLimit>5000</stackLimit>
  </ThingDef>

  <ThingDef Class="CombatExtended.AmmoDef" ParentName="KT_StandardLaserCellBase">
    <defName>Ammo_KT_StandardLaserCell</defName>
    <label>KT standard laser cell</label>
    <graphicData>
      <texPath>Things/Ammo/Charged/SmallRegular</texPath>
      <graphicClass>Graphic_StackCount</graphicClass>
    </graphicData>
    <ammoClass>KT_Laser</ammoClass>
  </ThingDef>

  <ThingDef Class="CombatExtended.AmmoDef" ParentName="KT_StandardLaserCellBase">
    <defName>Ammo_KT_StandardLaserCell_Focused</defName>
    <label>KT standard laser cell (Focused)</label>
    <graphicData>
      <texPath>Things/Ammo/Charged/SmallConc</texPath>
      <graphicClass>Graphic_StackCount</graphicClass>
    </graphicData>
    <ammoClass>KT_LaserFocused</ammoClass>
    <generateAllowChance>0.15</generateAllowChance>
  </ThingDef>

  <ThingDef Class="CombatExtended.AmmoDef" ParentName="KT_StandardLaserCellBase">
    <defName>Ammo_KT_StandardLaserCell_Pulse</defName>
    <label>KT standard laser cell (Pulse)</label>
    <graphicData>
      <texPath>Things/Ammo/Charged/SmallIon</texPath>
      <graphicClass>Graphic_StackCount</graphicClass>
    </graphicData>
    <ammoClass>KT_LaserPulse</ammoClass>
    <generateAllowChance>0.15</generateAllowChance>
  </ThingDef>

  <!-- ================== Projectiles (CE LaserBeam system) ================== -->

  <ThingDef Class="CombatExtended.Lasers.LaserBeamDefCE" Name="BaseKT_StandardLaserCellBeam" ParentName="BaseLaserBullet" Abstract="true">
    <textures>
      <li>Things/Mote/Mote_KT_flashlight</li>
    </textures>
    <beamWidth>0.7</beamWidth>
    <lifetime>4</lifetime>
    <projectile Class="CombatExtended.ProjectilePropertiesCE">
      <damageDef>CE_Laser</damageDef>
      <isInstant>true</isInstant>
    </projectile>
  </ThingDef>

  <ThingDef Class="CombatExtended.Lasers.LaserBeamDefCE" ParentName="BaseKT_StandardLaserCellBeam">
    <defName>Bullet_KT_StandardLaserCell</defName>
    <label>KT standard laser beam</label>
    <projectile Class="CombatExtended.ProjectilePropertiesCE">
      <damageAmountBase>32</damageAmountBase>
      <secondaryDamage>
        <li>
          <def>Bomb_Secondary</def>
          <amount>12</amount>
        </li>
      </secondaryDamage>
      <armorPenetrationSharp>68</armorPenetrationSharp>
      <armorPenetrationBlunt>0.5</armorPenetrationBlunt>
    </projectile>
  </ThingDef>

  <ThingDef Class="CombatExtended.Lasers.LaserBeamDefCE" ParentName="BaseKT_StandardLaserCellBeam">
    <defName>Bullet_KT_StandardLaserCell_Focused</defName>
    <label>KT standard laser beam (Focused)</label>
    <projectile Class="CombatExtended.ProjectilePropertiesCE">
      <damageAmountBase>26</damageAmountBase>
      <armorPenetrationSharp>125</armorPenetrationSharp>
      <armorPenetrationBlunt>0.5</armorPenetrationBlunt>
    </projectile>
  </ThingDef>

  <ThingDef Class="CombatExtended.Lasers.LaserBeamDefCE" ParentName="BaseKT_StandardLaserCellBeam">
    <defName>Bullet_KT_StandardLaserCell_Pulse</defName>
    <label>KT standard laser beam (Pulse)</label>
    <projectile Class="CombatExtended.ProjectilePropertiesCE">
      <damageAmountBase>35</damageAmountBase>
      <secondaryDamage>
        <li>
          <def>EMP</def>
          <amount>18</amount>
        </li>
      </secondaryDamage>
      <armorPenetrationSharp>50</armorPenetrationSharp>
      <armorPenetrationBlunt>0.5</armorPenetrationBlunt>
    </projectile>
  </ThingDef>

  <!-- ==================== Recipes ========================== -->

  <RecipeDef ParentName="ChargeAmmoRecipeBase">
    <defName>MakeAmmo_KT_StandardLaserCell</defName>
    <label>make KT standard laser cell x500</label>
    <description>Craft 500 KT standard laser cells.</description>
    <jobString>Making KT standard laser cells.</jobString>
    <ingredients>
      <li>
        <filter>
          <thingDefs><li>Plasteel</li></thingDefs>
        </filter>
        <count>30</count>
      </li>
      <li>
        <filter>
          <thingDefs><li>Steel</li></thingDefs>
        </filter>
        <count>15</count>
      </li>
      <li>
        <filter>
          <thingDefs><li>ComponentIndustrial</li></thingDefs>
        </filter>
        <count>6</count>
      </li>
    </ingredients>
    <fixedIngredientFilter>
      <thingDefs>
        <li>Plasteel</li>
        <li>Steel</li>
        <li>ComponentIndustrial</li>
      </thingDefs>
    </fixedIngredientFilter>
    <products>
      <Ammo_KT_StandardLaserCell>500</Ammo_KT_StandardLaserCell>
    </products>
    <workAmount>12000</workAmount>
  </RecipeDef>

  <RecipeDef ParentName="ChargeAmmoRecipeBase">
    <defName>MakeAmmo_KT_StandardLaserCell_Focused</defName>
    <label>make KT standard laser cell (Focused) x500</label>
    <description>Craft 500 KT standard laser cells (Focused).</description>
    <jobString>Making KT standard laser cells (Focused).</jobString>
    <ingredients>
      <li>
        <filter>
          <thingDefs><li>Plasteel</li></thingDefs>
        </filter>
        <count>30</count>
      </li>
      <li>
        <filter>
          <thingDefs><li>Steel</li></thingDefs>
        </filter>
        <count>15</count>
      </li>
      <li>
        <filter>
          <thingDefs><li>ComponentIndustrial</li></thingDefs>
        </filter>
        <count>8</count>
      </li>
    </ingredients>
    <fixedIngredientFilter>
      <thingDefs>
        <li>Plasteel</li>
        <li>Steel</li>
        <li>ComponentIndustrial</li>
      </thingDefs>
    </fixedIngredientFilter>
    <products>
      <Ammo_KT_StandardLaserCell_Focused>500</Ammo_KT_StandardLaserCell_Focused>
    </products>
    <workAmount>13500</workAmount>
  </RecipeDef>

  <RecipeDef ParentName="ChargeAmmoRecipeBase">
    <defName>MakeAmmo_KT_StandardLaserCell_Pulse</defName>
    <label>make KT standard laser cell (Pulse) x500</label>
    <description>Craft 500 KT standard laser cells (Pulse).</description>
    <jobString>Making KT standard laser cells (Pulse).</jobString>
    <ingredients>
      <li>
        <filter>
          <thingDefs><li>Plasteel</li></thingDefs>
        </filter>
        <count>30</count>
      </li>
      <li>
        <filter>
          <thingDefs><li>Steel</li></thingDefs>
        </filter>
        <count>15</count>
      </li>
      <li>
        <filter>
          <thingDefs><li>ComponentIndustrial</li></thingDefs>
        </filter>
        <count>8</count>
      </li>
    </ingredients>
    <fixedIngredientFilter>
      <thingDefs>
        <li>Plasteel</li>
        <li>Steel</li>
        <li>ComponentIndustrial</li>
      </thingDefs>
    </fixedIngredientFilter>
    <products>
      <Ammo_KT_StandardLaserCell_Pulse>500</Ammo_KT_StandardLaserCell_Pulse>
    </products>
    <workAmount>13500</workAmount>
  </RecipeDef>

</Defs>
