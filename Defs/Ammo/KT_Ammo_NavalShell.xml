<?xml version="1.0" encoding="utf-8"?>
<Defs>

  <ThingCategoryDef>
    <defName>AmmoKT_NavalShell</defName>
    <label>KT Naval Shell</label>
    <parent>AmmoAdvanced</parent>
    <iconPath>UI/Icons/ThingCategories/CaliberChargeLarge</iconPath>
  </ThingCategoryDef>

  <!-- ==================== AmmoSet ========================== -->

  <CombatExtended.AmmoSetDef>
    <defName>AmmoSet_KT_NavalShell</defName>
    <label>KT Naval Shell</label>
    <ammoTypes>
      <Ammo_KT_NavalShell_HE>Bullet_KT_NavalShell_HE</Ammo_KT_NavalShell_HE>
      <Ammo_KT_NavalShell_HEAT>Bullet_KT_NavalShell_HEAT</Ammo_KT_NavalShell_HEAT>
    </ammoTypes>
  </CombatExtended.AmmoSetDef>

  <!-- ==================== Ammo ========================== -->

  <ThingDef Class="CombatExtended.AmmoDef" Name="KT_NavalShellBase" ParentName="HeavyAmmoBase" Abstract="True">
    <description>Naval artillery shell for the KT handheld ship cannon.</description>
    <statBases>
      <Mass>1.0</Mass>
      <Bulk>1.5</Bulk>
    </statBases>
    <tradeTags>
      <li>CE_AutoEnableTrade</li>
      <li>CE_AutoEnableCrafting_FabricationBench</li>
    </tradeTags>
    <thingCategories>
      <li>AmmoKT_NavalShell</li>
    </thingCategories>
    <stackLimit>75</stackLimit>
  </ThingDef>

  <ThingDef Class="CombatExtended.AmmoDef" ParentName="KT_NavalShellBase">
    <defName>Ammo_KT_NavalShell_HE</defName>
    <label>KT naval shell (HE)</label>
    <graphicData>
      <texPath>Things/Ammo/Mortar/HE</texPath>
      <graphicClass>Graphic_StackCount</graphicClass>
    </graphicData>
    <ammoClass>KT_NavalShellHE</ammoClass>
  </ThingDef>

  <ThingDef Class="CombatExtended.AmmoDef" ParentName="KT_NavalShellBase">
    <defName>Ammo_KT_NavalShell_HEAT</defName>
    <label>KT naval shell (HEAT)</label>
    <graphicData>
      <texPath>Things/Ammo/Mortar/HE</texPath>
      <graphicClass>Graphic_StackCount</graphicClass>
    </graphicData>
    <ammoClass>KT_NavalShellHEAT</ammoClass>
    <generateAllowChance>0.15</generateAllowChance>
  </ThingDef>

  <!-- ================== Projectiles ================== -->

  <ThingDef ParentName="BaseExplosiveBullet">
    <defName>Bullet_KT_NavalShell_HE</defName>
    <thingClass>CombatExtended.ProjectileCE_Explosive</thingClass>
    <label>KT naval shell (HE)</label>
    <graphicData>
      <texPath>Things/Projectile/Bullet_100MM</texPath>
      <graphicClass>Graphic_Single</graphicClass>
      <shaderType>MoteGlow</shaderType>
      <drawSize>(3,3)</drawSize>
    </graphicData>
    <projectile Class="CombatExtended.ProjectilePropertiesCE">
      <damageDef>Bomb</damageDef>
      <damageAmountBase>450</damageAmountBase>
      <speed>150</speed>
      <armorPenetrationSharp>200</armorPenetrationSharp>
      <armorPenetrationBlunt>0</armorPenetrationBlunt>
      <explosionRadius>4</explosionRadius>
      <soundExplode>Explosion_Rocket</soundExplode>
      <soundHitThickRoof>Artillery_HitThickRoof</soundHitThickRoof>
      <soundImpactAnticipate>MortarRound_PreImpact</soundImpactAnticipate>
      <soundAmbient>MortarRound_Ambient</soundAmbient>
      <applyDamageToExplosionCellsNeighbors>true</applyDamageToExplosionCellsNeighbors>
    </projectile>
    <modExtensions>
      <li Class="ProjectileImpactFX.EffectProjectileExtension">
        <AutoAssign>false</AutoAssign>
        <CreateTerrainEffects>false</CreateTerrainEffects>
      </li>
    </modExtensions>
  </ThingDef>

  <ThingDef ParentName="BaseExplosiveBullet">
    <defName>Bullet_KT_NavalShell_HEAT</defName>
    <thingClass>CombatExtended.ProjectileCE_Explosive</thingClass>
    <label>KT naval shell (HEAT)</label>
    <graphicData>
      <texPath>Things/Projectile/Bullet_100MM</texPath>
      <graphicClass>Graphic_Single</graphicClass>
      <shaderType>MoteGlow</shaderType>
      <drawSize>(3,3)</drawSize>
    </graphicData>
    <projectile Class="CombatExtended.ProjectilePropertiesCE">
      <damageDef>Bomb</damageDef>
      <damageAmountBase>200</damageAmountBase>
      <speed>150</speed>
      <armorPenetrationSharp>500</armorPenetrationSharp>
      <armorPenetrationBlunt>0</armorPenetrationBlunt>
      <explosionRadius>1.5</explosionRadius>
      <soundExplode>Explosion_Rocket</soundExplode>
      <soundHitThickRoof>Artillery_HitThickRoof</soundHitThickRoof>
      <soundImpactAnticipate>MortarRound_PreImpact</soundImpactAnticipate>
      <soundAmbient>MortarRound_Ambient</soundAmbient>
      <applyDamageToExplosionCellsNeighbors>true</applyDamageToExplosionCellsNeighbors>
    </projectile>
    <modExtensions>
      <li Class="ProjectileImpactFX.EffectProjectileExtension">
        <AutoAssign>false</AutoAssign>
        <CreateTerrainEffects>false</CreateTerrainEffects>
      </li>
    </modExtensions>
  </ThingDef>

  <!-- ==================== Recipes ========================== -->

  <RecipeDef ParentName="ChargeAmmoRecipeBase">
    <defName>MakeAmmo_KT_NavalShell_HE</defName>
    <label>make KT naval shell (HE) x25</label>
    <description>Craft 25 KT naval shells (HE).</description>
    <jobString>Making KT naval shells (HE).</jobString>
    <ingredients>
      <li>
        <filter>
          <thingDefs><li>Plasteel</li></thingDefs>
        </filter>
        <count>80</count>
      </li>
      <li>
        <filter>
          <thingDefs><li>Steel</li></thingDefs>
        </filter>
        <count>40</count>
      </li>
      <li>
        <filter>
          <thingDefs><li>ComponentIndustrial</li></thingDefs>
        </filter>
        <count>20</count>
      </li>
    </ingredients>
    <fixedIngredientFilter>
      <thingDefs>
        <li>Plasteel</li>
        <li>Steel</li>
        <li>ComponentIndustrial</li>
      </thingDefs>
    </fixedIngredientFilter>
    <products>
      <Ammo_KT_NavalShell_HE>25</Ammo_KT_NavalShell_HE>
    </products>
    <workAmount>30000</workAmount>
  </RecipeDef>

  <RecipeDef ParentName="ChargeAmmoRecipeBase">
    <defName>MakeAmmo_KT_NavalShell_HEAT</defName>
    <label>make KT naval shell (HEAT) x25</label>
    <description>Craft 25 KT naval shells (HEAT).</description>
    <jobString>Making KT naval shells (HEAT).</jobString>
    <ingredients>
      <li>
        <filter>
          <thingDefs><li>Plasteel</li></thingDefs>
        </filter>
        <count>80</count>
      </li>
      <li>
        <filter>
          <thingDefs><li>Steel</li></thingDefs>
        </filter>
        <count>40</count>
      </li>
      <li>
        <filter>
          <thingDefs><li>ComponentIndustrial</li></thingDefs>
        </filter>
        <count>20</count>
      </li>
    </ingredients>
    <fixedIngredientFilter>
      <thingDefs>
        <li>Plasteel</li>
        <li>Steel</li>
        <li>ComponentIndustrial</li>
      </thingDefs>
    </fixedIngredientFilter>
    <products>
      <Ammo_KT_NavalShell_HEAT>25</Ammo_KT_NavalShell_HEAT>
    </products>
    <workAmount>30000</workAmount>
  </RecipeDef>

</Defs>
