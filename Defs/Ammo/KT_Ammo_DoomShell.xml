<?xml version="1.0" encoding="utf-8"?>
<Defs>

  <ThingCategoryDef>
    <defName>AmmoKT_DoomShell</defName>
    <label>KT Doom Shell</label>
    <parent>AmmoAdvanced</parent>
    <iconPath>UI/Icons/ThingCategories/CaliberChargeLarge</iconPath>
  </ThingCategoryDef>

  <!-- ==================== AmmoSet ========================== -->

  <CombatExtended.AmmoSetDef>
    <defName>AmmoSet_KT_DoomShell</defName>
    <label>KT Doom Shell</label>
    <ammoTypes>
      <Ammo_KT_DoomShell>Bullet_KT_DoomShell</Ammo_KT_DoomShell>
    </ammoTypes>
  </CombatExtended.AmmoSetDef>

  <!-- ==================== Ammo ========================== -->

  <ThingDef Class="CombatExtended.AmmoDef" ParentName="HeavyAmmoBase">
    <defName>Ammo_KT_DoomShell</defName>
    <label>KT doom shell</label>
    <description>Annihilation warhead for the KT Doom Launcher. Devastating area-denial ordnance capable of obliterating entire squads.</description>
    <graphicData>
      <texPath>Things/Ammo/Mortar/HE</texPath>
      <graphicClass>Graphic_StackCount</graphicClass>
    </graphicData>
    <statBases>
      <Mass>5.0</Mass>
      <Bulk>8.0</Bulk>
    </statBases>
    <tradeTags>
      <li>CE_AutoEnableTrade</li>
      <li>CE_AutoEnableCrafting_FabricationBench</li>
    </tradeTags>
    <thingCategories>
      <li>AmmoKT_DoomShell</li>
    </thingCategories>
    <stackLimit>10</stackLimit>
    <ammoClass>KT_DoomShell</ammoClass>
  </ThingDef>

  <!-- ================== Projectiles ================== -->

  <ThingDef ParentName="BaseExplosiveBullet">
    <defName>Bullet_KT_DoomShell</defName>
    <thingClass>CombatExtended.ProjectileCE_Explosive</thingClass>
    <label>KT doom shell</label>
    <graphicData>
      <texPath>Things/Projectile/Bullet_381MM</texPath>
      <graphicClass>Graphic_Single</graphicClass>
      <shaderType>MoteGlow</shaderType>
      <drawSize>(4,4)</drawSize>
    </graphicData>
    <projectile Class="CombatExtended.ProjectilePropertiesCE">
      <damageDef>Bomb</damageDef>
      <damageAmountBase>2500</damageAmountBase>
      <speed>60</speed>
      <armorPenetrationSharp>300</armorPenetrationSharp>
      <armorPenetrationBlunt>0</armorPenetrationBlunt>
      <explosionRadius>20</explosionRadius>
      <soundExplode>Explosion_Rocket</soundExplode>
      <soundHitThickRoof>Artillery_HitThickRoof</soundHitThickRoof>
      <soundImpactAnticipate>MortarRound_PreImpact</soundImpactAnticipate>
      <soundAmbient>MortarRound_Ambient</soundAmbient>
      <applyDamageToExplosionCellsNeighbors>true</applyDamageToExplosionCellsNeighbors>
    </projectile>
    <modExtensions>
      <li Class="ProjectileImpactFX.EffectProjectileExtension">
        <AutoAssign>false</AutoAssign>
        <CreateTerrainEffects>false</CreateTerrainEffects>
      </li>
    </modExtensions>
  </ThingDef>

  <!-- ==================== Recipes ========================== -->

  <RecipeDef ParentName="ChargeAmmoRecipeBase">
    <defName>MakeAmmo_KT_DoomShell</defName>
    <label>make KT doom shell x5</label>
    <description>Craft 5 KT doom shells.</description>
    <jobString>Making KT doom shells.</jobString>
    <ingredients>
      <li>
        <filter>
          <thingDefs><li>Plasteel</li></thingDefs>
        </filter>
        <count>120</count>
      </li>
      <li>
        <filter>
          <thingDefs><li>Steel</li></thingDefs>
        </filter>
        <count>60</count>
      </li>
      <li>
        <filter>
          <thingDefs><li>ComponentSpacer</li></thingDefs>
        </filter>
        <count>5</count>
      </li>
    </ingredients>
    <fixedIngredientFilter>
      <thingDefs>
        <li>Plasteel</li>
        <li>Steel</li>
        <li>ComponentSpacer</li>
      </thingDefs>
    </fixedIngredientFilter>
    <products>
      <Ammo_KT_DoomShell>5</Ammo_KT_DoomShell>
    </products>
    <workAmount>50000</workAmount>
  </RecipeDef>

</Defs>
