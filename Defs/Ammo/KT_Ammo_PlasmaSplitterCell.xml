<?xml version="1.0" encoding="utf-8"?>
<Defs>

  <ThingCategoryDef>
    <defName>AmmoKT_PlasmaSplitterCell</defName>
    <label>KT Plasma Splitter Cell</label>
    <parent>AmmoAdvanced</parent>
    <iconPath>UI/Icons/ThingCategories/CaliberChargeLarge</iconPath>
  </ThingCategoryDef>

  <!-- ==================== AmmoSet ========================== -->

  <CombatExtended.AmmoSetDef>
    <defName>AmmoSet_KT_PlasmaSplitterCell</defName>
    <label>KT Plasma Splitter Cell</label>
    <ammoTypes>
      <Ammo_KT_PlasmaSplitterCell>Bullet_KT_PlasmaSplitterCell</Ammo_KT_PlasmaSplitterCell>
      <Ammo_KT_PlasmaSplitterCell_Focused>Bullet_KT_PlasmaSplitterCell_Focused</Ammo_KT_PlasmaSplitterCell_Focused>
    </ammoTypes>
  </CombatExtended.AmmoSetDef>

  <!-- ==================== Ammo ========================== -->

  <ThingDef Class="CombatExtended.AmmoDef" Name="KT_PlasmaSplitterCellBase" ParentName="SpacerMediumAmmoBase" Abstract="True">
    <description>High-energy plasma cell for the UF plasma splitter cannon. Detonates in a burst of ionized plasma that shreds both armor and electronics.</description>
    <statBases>
      <Mass>0.08</Mass>
      <Bulk>0.12</Bulk>
    </statBases>
    <tradeTags>
      <li>CE_AutoEnableTrade</li>
      <li>CE_AutoEnableCrafting_FabricationBench</li>
    </tradeTags>
    <thingCategories>
      <li>AmmoKT_PlasmaSplitterCell</li>
    </thingCategories>
    <stackLimit>500</stackLimit>
  </ThingDef>

  <ThingDef Class="CombatExtended.AmmoDef" ParentName="KT_PlasmaSplitterCellBase">
    <defName>Ammo_KT_PlasmaSplitterCell</defName>
    <label>KT plasma splitter cell</label>
    <graphicData>
      <texPath>Things/Ammo/Charged/LargeRegular</texPath>
      <graphicClass>Graphic_StackCount</graphicClass>
    </graphicData>
    <ammoClass>KT_PlasmaSplitter</ammoClass>
  </ThingDef>

  <ThingDef Class="CombatExtended.AmmoDef" ParentName="KT_PlasmaSplitterCellBase">
    <defName>Ammo_KT_PlasmaSplitterCell_Focused</defName>
    <label>KT plasma splitter cell (Focused)</label>
    <graphicData>
      <texPath>Things/Ammo/Charged/LargeConc</texPath>
      <graphicClass>Graphic_StackCount</graphicClass>
    </graphicData>
    <ammoClass>KT_PlasmaSplitterFocused</ammoClass>
    <generateAllowChance>0.15</generateAllowChance>
  </ThingDef>

  <!-- ==================== Projectiles ========================== -->

  <ThingDef>
    <defName>Bullet_KT_PlasmaSplitterCell</defName>
    <label>KT plasma splitter bolt</label>
    <thingClass>CombatExtended.ProjectileCE_Explosive</thingClass>
    <graphicData>
      <texPath>Things/Projectile/Bullet_kt_plasma</texPath>
      <graphicClass>Graphic_Single</graphicClass>
      <shaderType>MoteGlow</shaderType>
      <drawSize>(1.5,1.5)</drawSize>
    </graphicData>
    <projectile Class="CombatExtended.ProjectilePropertiesCE">
      <damageDef>KTBLUEBomb</damageDef>
      <damageAmountBase>120</damageAmountBase>
      <explosionRadius>3</explosionRadius>
      <armorPenetrationSharp>60</armorPenetrationSharp>
      <armorPenetrationBlunt>0</armorPenetrationBlunt>
      <speed>120</speed>
      <soundExplode>Explosion_Bomb</soundExplode>
    </projectile>
    <modExtensions>
      <li Class="UFHeavyIndustries_CE.MultiExplosionCEExtension">
        <subExplosions>
          <li>
            <damageDef>KTBLUEBomb</damageDef>
            <radius>3</radius>
            <damageAmount>120</damageAmount>
            <armorPenetration>1.5</armorPenetration>
            <explosionSound>Explosion_Bomb</explosionSound>
            <damageFalloff>true</damageFalloff>
            <onlyAntiHostile>true</onlyAntiHostile>
          </li>
          <li>
            <damageDef>EMP</damageDef>
            <radius>4</radius>
            <damageAmount>60</damageAmount>
            <armorPenetration>8</armorPenetration>
            <explosionSound>Explosion_EMP</explosionSound>
            <damageFalloff>true</damageFalloff>
            <onlyAntiHostile>true</onlyAntiHostile>
          </li>
        </subExplosions>
        <subProjectiles>
          <li>
            <projectileDef>KT_Bullet_Splitter_Gun_bulletLaunches</projectileDef>
            <count>8</count>
            <angleRange>120</angleRange>
            <distanceRange><min>4</min><max>8</max></distanceRange>
          </li>
        </subProjectiles>
      </li>
      <li Class="UFHeavyIndustries_CE.ProjectileEffectsExtension">
        <tailFleckDef>KT_Fleck_blue_particle_Tail</tailFleckDef>
        <tailFleckTickInterval>10</tailFleckTickInterval>
        <tailFleckDelayTicks>5</tailFleckDelayTicks>
        <tailFleckCount>4</tailFleckCount>
      </li>
      <li Class="ProjectileImpactFX.EffectProjectileExtension">
        <AutoAssign>false</AutoAssign>
        <CreateTerrainEffects>false</CreateTerrainEffects>
      </li>
    </modExtensions>
  </ThingDef>

  <ThingDef>
    <defName>Bullet_KT_PlasmaSplitterCell_Focused</defName>
    <label>KT plasma splitter bolt (Focused)</label>
    <thingClass>CombatExtended.ProjectileCE_Explosive</thingClass>
    <graphicData>
      <texPath>Things/Projectile/Bullet_kt_plasma</texPath>
      <graphicClass>Graphic_Single</graphicClass>
      <shaderType>MoteGlow</shaderType>
      <drawSize>(1.5,1.5)</drawSize>
    </graphicData>
    <projectile Class="CombatExtended.ProjectilePropertiesCE">
      <damageDef>KTBLUEBomb</damageDef>
      <damageAmountBase>90</damageAmountBase>
      <explosionRadius>1.5</explosionRadius>
      <armorPenetrationSharp>120</armorPenetrationSharp>
      <armorPenetrationBlunt>0</armorPenetrationBlunt>
      <speed>120</speed>
    </projectile>
    <modExtensions>
      <li Class="ProjectileImpactFX.EffectProjectileExtension">
        <AutoAssign>false</AutoAssign>
        <CreateTerrainEffects>false</CreateTerrainEffects>
      </li>
    </modExtensions>
  </ThingDef>

  <!-- ==================== Recipes ========================== -->

  <RecipeDef ParentName="ChargeAmmoRecipeBase">
    <defName>MakeAmmo_KT_PlasmaSplitterCell</defName>
    <label>make KT plasma splitter cell x100</label>
    <description>Craft 100 KT plasma splitter cells.</description>
    <jobString>Making KT plasma splitter cells.</jobString>
    <ingredients>
      <li>
        <filter>
          <thingDefs><li>Plasteel</li></thingDefs>
        </filter>
        <count>40</count>
      </li>
      <li>
        <filter>
          <thingDefs><li>Steel</li></thingDefs>
        </filter>
        <count>20</count>
      </li>
      <li>
        <filter>
          <thingDefs><li>ComponentIndustrial</li></thingDefs>
        </filter>
        <count>10</count>
      </li>
    </ingredients>
    <fixedIngredientFilter>
      <thingDefs>
        <li>Plasteel</li>
        <li>Steel</li>
        <li>ComponentIndustrial</li>
      </thingDefs>
    </fixedIngredientFilter>
    <products>
      <Ammo_KT_PlasmaSplitterCell>100</Ammo_KT_PlasmaSplitterCell>
    </products>
    <workAmount>15000</workAmount>
  </RecipeDef>

  <RecipeDef ParentName="ChargeAmmoRecipeBase">
    <defName>MakeAmmo_KT_PlasmaSplitterCell_Focused</defName>
    <label>make KT plasma splitter cell (Focused) x100</label>
    <description>Craft 100 KT plasma splitter cells (Focused).</description>
    <jobString>Making KT plasma splitter cells (Focused).</jobString>
    <ingredients>
      <li>
        <filter>
          <thingDefs><li>Plasteel</li></thingDefs>
        </filter>
        <count>40</count>
      </li>
      <li>
        <filter>
          <thingDefs><li>Steel</li></thingDefs>
        </filter>
        <count>20</count>
      </li>
      <li>
        <filter>
          <thingDefs><li>ComponentIndustrial</li></thingDefs>
        </filter>
        <count>12</count>
      </li>
    </ingredients>
    <fixedIngredientFilter>
      <thingDefs>
        <li>Plasteel</li>
        <li>Steel</li>
        <li>ComponentIndustrial</li>
      </thingDefs>
    </fixedIngredientFilter>
    <products>
      <Ammo_KT_PlasmaSplitterCell_Focused>100</Ammo_KT_PlasmaSplitterCell_Focused>
    </products>
    <workAmount>18000</workAmount>
  </RecipeDef>

</Defs>
