  <RecipeDef ParentName="ChargeAmmoRecipeBase">
    <defName>MakeAmmo_KT_LightLaserCell_Pulse</defName>
    <label>make KT light laser cell (Pulse) x500</label>
    <description>Craft 500 KT light laser cells (Pulse).</description>
    <jobString>Making KT light laser cells (Pulse).</jobString>
