<?xml version="1.0" encoding="utf-8"?>
<Defs>

  <ThingCategoryDef>
    <defName>AmmoKT_LightLaserCell</defName>
    <label>KT Light Laser Cell</label>
    <parent>AmmoAdvanced</parent>
    <iconPath>UI/Icons/ThingCategories/CaliberCharge</iconPath>
  </ThingCategoryDef>

  <!-- ==================== AmmoSet ========================== -->

  <CombatExtended.AmmoSetDef>
    <defName>AmmoSet_KT_LightLaserCell</defName>
    <label>KT Light Laser Cell</label>
    <ammoTypes>
      <Ammo_KT_LightLaserCell>Bullet_KT_LightLaserCell</Ammo_KT_LightLaserCell>
      <Ammo_KT_LightLaserCell_Focused>Bullet_KT_LightLaserCell_Focused</Ammo_KT_LightLaserCell_Focused>
      <Ammo_KT_LightLaserCell_Pulse>Bullet_KT_LightLaserCell_Pulse</Ammo_KT_LightLaserCell_Pulse>
    </ammoTypes>
  </CombatExtended.AmmoSetDef>

  <!-- ==================== Ammo ========================== -->

  <ThingDef Class="CombatExtended.AmmoDef" Name="KT_LightLaserCellBase" ParentName="SpacerSmallAmmoBase" Abstract="True">
    <description>Compact energy cell for UF covenant light laser weapons.</description>
    <statBases>
      <Mass>0.01</Mass>
      <Bulk>0.02</Bulk>
    </statBases>
    <tradeTags>
      <li>CE_AutoEnableTrade</li>
      <li>CE_AutoEnableCrafting_FabricationBench</li>
    </tradeTags>
    <thingCategories>
      <li>AmmoKT_LightLaserCell</li>
    </thingCategories>
    <stackLimit>5000</stackLimit>
  </ThingDef>

  <ThingDef Class="CombatExtended.AmmoDef" ParentName="KT_LightLaserCellBase">
    <defName>Ammo_KT_LightLaserCell</defName>
    <label>KT light laser cell</label>
    <graphicData>
      <texPath>Things/Ammo/Charged/SmallRegular</texPath>
      <graphicClass>Graphic_StackCount</graphicClass>
    </graphicData>
    <ammoClass>Charged</ammoClass>
  </ThingDef>

  <ThingDef Class="CombatExtended.AmmoDef" ParentName="KT_LightLaserCellBase">
    <defName>Ammo_KT_LightLaserCell_Focused</defName>
    <label>KT light laser cell (Focused)</label>
    <graphicData>
      <texPath>Things/Ammo/Charged/SmallConc</texPath>
      <graphicClass>Graphic_StackCount</graphicClass>
    </graphicData>
    <ammoClass>ChargedAP</ammoClass>
    <generateAllowChance>0.15</generateAllowChance>
  </ThingDef>

  <ThingDef Class="CombatExtended.AmmoDef" ParentName="KT_LightLaserCellBase">
    <defName>Ammo_KT_LightLaserCell_Pulse</defName>
    <label>KT light laser cell (Pulse)</label>
    <graphicData>
      <texPath>Things/Ammo/Charged/SmallIon</texPath>
      <graphicClass>Graphic_StackCount</graphicClass>
    </graphicData>
    <ammoClass>Ionized</ammoClass>
    <generateAllowChance>0.15</generateAllowChance>
  </ThingDef>

  <!-- ================== Projectiles ================== -->

  <ThingDef Name="BaseKT_LightLaserCellBullet" ParentName="BaseBulletCE" Abstract="true">
    <graphicData>
      <texPath>Things/Projectile/Charged/ChargeShot</texPath>
      <graphicClass>Graphic_Single</graphicClass>
      <shaderType>TransparentPostLight</shaderType>
    </graphicData>
    <projectile Class="CombatExtended.ProjectilePropertiesCE">
      <damageDef>Bullet</damageDef>
    </projectile>
  </ThingDef>

  <ThingDef ParentName="BaseKT_LightLaserCellBullet">
    <defName>Bullet_KT_LightLaserCell</defName>
    <label>KT light laser bolt</label>
    <projectile Class="CombatExtended.ProjectilePropertiesCE">
      <damageAmountBase>20</damageAmountBase>
      <speed>165</speed>
      <secondaryDamage>
        <li>
          <def>Bomb_Secondary</def>
          <amount>8</amount>
        </li>
      </secondaryDamage>
      <armorPenetrationSharp>42</armorPenetrationSharp>
      <armorPenetrationBlunt>160</armorPenetrationBlunt>
    </projectile>
  </ThingDef>

  <ThingDef ParentName="BaseKT_LightLaserCellBullet">
    <defName>Bullet_KT_LightLaserCell_Focused</defName>
    <label>KT light laser bolt (Focused)</label>
    <projectile Class="CombatExtended.ProjectilePropertiesCE">
      <damageAmountBase>16</damageAmountBase>
      <speed>175</speed>
      <armorPenetrationSharp>80</armorPenetrationSharp>
      <armorPenetrationBlunt>160</armorPenetrationBlunt>
    </projectile>
  </ThingDef>

  <ThingDef ParentName="BaseKT_LightLaserCellBullet">
    <defName>Bullet_KT_LightLaserCell_Pulse</defName>
    <label>KT light laser bolt (Pulse)</label>
    <projectile Class="CombatExtended.ProjectilePropertiesCE">
      <damageAmountBase>22</damageAmountBase>
      <speed>155</speed>
      <secondaryDamage>
        <li>
          <def>EMP</def>
          <amount>12</amount>
        </li>
      </secondaryDamage>
      <armorPenetrationSharp>32</armorPenetrationSharp>
      <armorPenetrationBlunt>135</armorPenetrationBlunt>
    </projectile>
  </ThingDef>

  <!-- ==================== Recipes ========================== -->

  <RecipeDef ParentName="ChargeAmmoRecipeBase">
    <defName>MakeAmmo_KT_LightLaserCell</defName>
    <label>make KT light laser cell x500</label>
    <description>Craft 500 KT light laser cells.</description>
    <jobString>Making KT light laser cells.</jobString>
    <ingredients>
      <li>
        <filter>
          <thingDefs><li>Plasteel</li></thingDefs>
        </filter>
        <count>20</count>
      </li>
      <li>
        <filter>
          <thingDefs><li>Steel</li></thingDefs>
        </filter>
        <count>10</count>
      </li>
      <li>
        <filter>
          <thingDefs><li>ComponentIndustrial</li></thingDefs>
        </filter>
        <count>4</count>
      </li>
    </ingredients>
    <fixedIngredientFilter>
      <thingDefs>
        <li>Plasteel</li>
        <li>Steel</li>
        <li>ComponentIndustrial</li>
      </thingDefs>
    </fixedIngredientFilter>
    <products>
      <Ammo_KT_LightLaserCell>500</Ammo_KT_LightLaserCell>
    </products>
    <workAmount>8000</workAmount>
  </RecipeDef>

  <RecipeDef ParentName="ChargeAmmoRecipeBase">
    <defName>MakeAmmo_KT_LightLaserCell_Focused</defName>
    <label>make KT light laser cell (Focused) x500</label>
