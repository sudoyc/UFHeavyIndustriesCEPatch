<?xml version="1.0" encoding="utf-8"?>
<Defs>

  <ThingCategoryDef>
    <defName>AmmoKT_80mmMortarShell</defName>
    <label>KT 80mm Mortar Shell</label>
    <parent>AmmoAdvanced</parent>
    <iconPath>UI/Icons/ThingCategories/CaliberCannon</iconPath>
  </ThingCategoryDef>

  <!-- ==================== AmmoSet ========================== -->

  <CombatExtended.AmmoSetDef>
    <defName>AmmoSet_KT_80mmMortarShell</defName>
    <label>KT 80mm Mortar Shell</label>
    <ammoTypes>
      <Ammo_KT_80mmMortarShell_HE>Bullet_KT_80mmMortarShell_HE</Ammo_KT_80mmMortarShell_HE>
      <Ammo_KT_80mmMortarShell_Toxic MayRequire="Ludeon.RimWorld.Biotech">Bullet_KT_80mmMortarShell_Toxic</Ammo_KT_80mmMortarShell_Toxic>
    </ammoTypes>
  </CombatExtended.AmmoSetDef>

  <!-- ==================== Ammo ========================== -->

  <ThingDef Class="CombatExtended.AmmoDef" Name="KT_80mmMortarShellBase" ParentName="HeavyAmmoBase" Abstract="True">
    <description>80mm mortar shells for UF Heavy Industries mortar weapons.</description>
    <statBases>
      <Mass>4.0</Mass>
      <Bulk>6.0</Bulk>
    </statBases>
    <tradeTags>
      <li>CE_AutoEnableTrade</li>
      <li>CE_AutoEnableCrafting_TableMachining</li>
    </tradeTags>
    <thingCategories>
      <li>AmmoKT_80mmMortarShell</li>
    </thingCategories>
    <stackLimit>25</stackLimit>
  </ThingDef>

  <ThingDef Class="CombatExtended.AmmoDef" ParentName="KT_80mmMortarShellBase">
    <defName>Ammo_KT_80mmMortarShell_HE</defName>
    <label>80mm mortar shell (HE)</label>
    <graphicData>
      <texPath>Things/Ammo/Mortar/HE</texPath>
      <graphicClass>Graphic_StackCount</graphicClass>
    </graphicData>
    <ammoClass>GrenadeHE</ammoClass>
  </ThingDef>

  <ThingDef Class="CombatExtended.AmmoDef" ParentName="KT_80mmMortarShellBase" MayRequire="Ludeon.RimWorld.Biotech">
    <defName>Ammo_KT_80mmMortarShell_Toxic</defName>
    <label>80mm mortar shell (Toxic)</label>
    <graphicData>
      <texPath>Things/Ammo/Mortar/Toxic</texPath>
      <graphicClass>Graphic_StackCount</graphicClass>
    </graphicData>
    <ammoClass>Toxic</ammoClass>
  </ThingDef>

  <!-- ================== Projectiles ================== -->

  <ThingDef ParentName="BaseExplosiveBullet">
    <defName>Bullet_KT_80mmMortarShell_HE</defName>
    <thingClass>CombatExtended.ProjectileCE_Explosive</thingClass>
    <label>80mm mortar shell (HE)</label>
    <graphicData>
      <texPath>Things/Projectile/LauncherShot</texPath>
      <graphicClass>Graphic_Single</graphicClass>
      <shaderType>TransparentPostLight</shaderType>
    </graphicData>
    <projectile Class="CombatExtended.ProjectilePropertiesCE">
      <speed>0</speed>
      <damageDef>Bomb</damageDef>
      <damageAmountBase>120</damageAmountBase>
      <flyOverhead>true</flyOverhead>
      <gravityFactor>5</gravityFactor>
      <explosionRadius>3.5</explosionRadius>
      <soundExplode>MortarBomb_Explode</soundExplode>
      <soundHitThickRoof>Artillery_HitThickRoof</soundHitThickRoof>
      <soundImpactAnticipate>MortarRound_PreImpact</soundImpactAnticipate>
      <soundAmbient>MortarRound_Ambient</soundAmbient>
      <applyDamageToExplosionCellsNeighbors>true</applyDamageToExplosionCellsNeighbors>
    </projectile>
  </ThingDef>

  <ThingDef ParentName="BaseExplosiveBullet" MayRequire="Ludeon.RimWorld.Biotech">
    <defName>Bullet_KT_80mmMortarShell_Toxic</defName>
    <thingClass>CombatExtended.ProjectileCE_Explosive</thingClass>
    <label>80mm mortar shell (Toxic)</label>
    <graphicData>
      <texPath>Things/Projectile/LauncherShot</texPath>
      <graphicClass>Graphic_Single</graphicClass>
      <shaderType>TransparentPostLight</shaderType>
    </graphicData>
    <projectile Class="CombatExtended.ProjectilePropertiesCE">
      <speed>0</speed>
      <damageDef>Bomb</damageDef>
      <damageAmountBase>60</damageAmountBase>
      <flyOverhead>true</flyOverhead>
      <gravityFactor>5</gravityFactor>
      <explosionRadius>2.0</explosionRadius>
      <soundExplode>MortarBomb_Explode</soundExplode>
      <soundHitThickRoof>Artillery_HitThickRoof</soundHitThickRoof>
      <soundImpactAnticipate>MortarRound_PreImpact</soundImpactAnticipate>
      <soundAmbient>MortarRound_Ambient</soundAmbient>
      <applyDamageToExplosionCellsNeighbors>true</applyDamageToExplosionCellsNeighbors>
      <postExplosionGasType>ToxGas</postExplosionGasType>
    </projectile>
  </ThingDef>

  <!-- ==================== Recipes ========================== -->

  <RecipeDef ParentName="LauncherAmmoRecipeBase">
    <defName>MakeAmmo_KT_80mmMortarShell_HE</defName>
    <label>make 80mm mortar shell (HE) x5</label>
    <description>Craft 5 80mm mortar shells (HE).</description>
    <jobString>Making 80mm mortar shells (HE).</jobString>
    <ingredients>
      <li>
        <filter>
          <thingDefs><li>Steel</li></thingDefs>
        </filter>
        <count>40</count>
      </li>
      <li>
        <filter>
          <thingDefs><li>Chemfuel</li></thingDefs>
        </filter>
        <count>20</count>
      </li>
      <li>
        <filter>
          <thingDefs><li>ComponentIndustrial</li></thingDefs>
        </filter>
        <count>4</count>
      </li>
    </ingredients>
    <fixedIngredientFilter>
      <thingDefs>
        <li>Steel</li>
        <li>Chemfuel</li>
        <li>ComponentIndustrial</li>
      </thingDefs>
    </fixedIngredientFilter>
    <products>
      <Ammo_KT_80mmMortarShell_HE>5</Ammo_KT_80mmMortarShell_HE>
    </products>
    <workAmount>8000</workAmount>
  </RecipeDef>

  <RecipeDef ParentName="LauncherAmmoRecipeBase" MayRequire="Ludeon.RimWorld.Biotech">
    <defName>MakeAmmo_KT_80mmMortarShell_Toxic</defName>
    <label>make 80mm mortar shell (Toxic) x5</label>
    <description>Craft 5 80mm mortar shells (Toxic).</description>
    <jobString>Making 80mm mortar shells (Toxic).</jobString>
    <ingredients>
      <li>
        <filter>
          <thingDefs><li>Steel</li></thingDefs>
        </filter>
        <count>40</count>
      </li>
      <li>
        <filter>
          <thingDefs><li>Chemfuel</li></thingDefs>
        </filter>
        <count>15</count>
      </li>
      <li>
        <filter>
          <thingDefs><li>MedicineHerbal</li></thingDefs>
        </filter>
        <count>5</count>
      </li>
      <li>
        <filter>
          <thingDefs><li>ComponentIndustrial</li></thingDefs>
        </filter>
        <count>4</count>
      </li>
    </ingredients>
    <fixedIngredientFilter>
      <thingDefs>
        <li>Steel</li>
        <li>Chemfuel</li>
        <li>MedicineHerbal</li>
        <li>ComponentIndustrial</li>
      </thingDefs>
    </fixedIngredientFilter>
    <products>
      <Ammo_KT_80mmMortarShell_Toxic>5</Ammo_KT_80mmMortarShell_Toxic>
    </products>
    <workAmount>9000</workAmount>
  </RecipeDef>

</Defs>
