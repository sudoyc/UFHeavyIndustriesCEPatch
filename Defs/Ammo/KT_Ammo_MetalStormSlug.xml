<?xml version="1.0" encoding="utf-8"?>
<Defs>

  <ThingCategoryDef>
    <defName>AmmoKT_MetalStormSlug</defName>
    <label>KT Metal Storm Slug</label>
    <parent>AmmoAdvanced</parent>
    <iconPath>UI/Icons/ThingCategories/CaliberChargeLarge</iconPath>
  </ThingCategoryDef>

  <!-- ==================== AmmoSet ========================== -->

  <CombatExtended.AmmoSetDef>
    <defName>AmmoSet_KT_MetalStormSlug</defName>
    <label>KT Metal Storm Slug</label>
    <ammoTypes>
      <Ammo_KT_MetalStormSlug>Bullet_KT_MetalStormSlug</Ammo_KT_MetalStormSlug>
      <Ammo_KT_MetalStormSlug_AP>Bullet_KT_MetalStormSlug_AP</Ammo_KT_MetalStormSlug_AP>
    </ammoTypes>
  </CombatExtended.AmmoSetDef>

  <!-- ==================== Ammo ========================== -->

  <ThingDef Class="CombatExtended.AmmoDef" Name="KT_MetalStormSlugBase" ParentName="SpacerMediumAmmoBase" Abstract="True">
    <description>Electromagnetic metal slug for UF Heavy Industries weapons.</description>
    <statBases>
      <Mass>0.03</Mass>
      <Bulk>0.05</Bulk>
    </statBases>
    <tradeTags>
      <li>CE_AutoEnableTrade</li>
      <li>CE_AutoEnableCrafting_FabricationBench</li>
    </tradeTags>
    <thingCategories>
      <li>AmmoKT_MetalStormSlug</li>
    </thingCategories>
    <stackLimit>2500</stackLimit>
  </ThingDef>

  <ThingDef Class="CombatExtended.AmmoDef" ParentName="KT_MetalStormSlugBase">
    <defName>Ammo_KT_MetalStormSlug</defName>
    <label>KT metal storm slug</label>
    <graphicData>
      <texPath>Things/Ammo/Charged/LargeRegular</texPath>
      <graphicClass>Graphic_StackCount</graphicClass>
    </graphicData>
    <ammoClass>KT_MetalStorm</ammoClass>
  </ThingDef>

  <ThingDef Class="CombatExtended.AmmoDef" ParentName="KT_MetalStormSlugBase">
    <defName>Ammo_KT_MetalStormSlug_AP</defName>
    <label>KT metal storm slug (AP)</label>
    <graphicData>
      <texPath>Things/Ammo/Charged/LargeConc</texPath>
      <graphicClass>Graphic_StackCount</graphicClass>
    </graphicData>
    <ammoClass>KT_MetalStormAP</ammoClass>
    <generateAllowChance>0.15</generateAllowChance>
  </ThingDef>

  <!-- ================== Projectiles ================== -->

  <ThingDef Name="BaseKT_MetalStormSlugBullet" ParentName="BaseBulletCE" Abstract="true">
    <graphicData>
      <texPath>Things/Projectile/Charged/ChargeShot</texPath>
      <graphicClass>Graphic_Single</graphicClass>
      <shaderType>TransparentPostLight</shaderType>
    </graphicData>
    <projectile Class="CombatExtended.ProjectilePropertiesCE">
      <damageDef>Bullet</damageDef>
    </projectile>
  </ThingDef>

  <ThingDef ParentName="BaseKT_MetalStormSlugBullet">
    <defName>Bullet_KT_MetalStormSlug</defName>
    <label>KT metal storm slug</label>
    <projectile Class="CombatExtended.ProjectilePropertiesCE">
      <damageAmountBase>28</damageAmountBase>
      <speed>200</speed>
      <armorPenetrationSharp>135</armorPenetrationSharp>
      <armorPenetrationBlunt>520</armorPenetrationBlunt>
    </projectile>
  </ThingDef>

  <ThingDef ParentName="BaseKT_MetalStormSlugBullet">
    <defName>Bullet_KT_MetalStormSlug_AP</defName>
    <label>KT metal storm slug (AP)</label>
    <projectile Class="CombatExtended.ProjectilePropertiesCE">
      <damageAmountBase>22</damageAmountBase>
      <speed>210</speed>
      <armorPenetrationSharp>240</armorPenetrationSharp>
      <armorPenetrationBlunt>520</armorPenetrationBlunt>
    </projectile>
  </ThingDef>

  <!-- ==================== Recipes ========================== -->

  <RecipeDef ParentName="ChargeAmmoRecipeBase">
    <defName>MakeAmmo_KT_MetalStormSlug</defName>
    <label>make KT metal storm slug x300</label>
    <description>Craft 300 KT metal storm slugs.</description>
    <jobString>Making KT metal storm slugs.</jobString>
    <ingredients>
      <li>
        <filter>
          <thingDefs><li>Steel</li></thingDefs>
        </filter>
        <count>50</count>
      </li>
      <li>
        <filter>
          <thingDefs><li>Plasteel</li></thingDefs>
        </filter>
        <count>20</count>
      </li>
      <li>
        <filter>
          <thingDefs><li>ComponentIndustrial</li></thingDefs>
        </filter>
        <count>12</count>
      </li>
    </ingredients>
    <fixedIngredientFilter>
      <thingDefs>
        <li>Steel</li>
        <li>Plasteel</li>
        <li>ComponentIndustrial</li>
      </thingDefs>
    </fixedIngredientFilter>
    <products>
      <Ammo_KT_MetalStormSlug>300</Ammo_KT_MetalStormSlug>
    </products>
    <workAmount>15000</workAmount>
  </RecipeDef>

  <RecipeDef ParentName="ChargeAmmoRecipeBase">
    <defName>MakeAmmo_KT_MetalStormSlug_AP</defName>
    <label>make KT metal storm slug (AP) x300</label>
    <description>Craft 300 KT metal storm slugs (AP).</description>
    <jobString>Making KT metal storm slugs (AP).</jobString>
    <ingredients>
      <li>
        <filter>
          <thingDefs><li>Steel</li></thingDefs>
        </filter>
        <count>50</count>
      </li>
      <li>
        <filter>
          <thingDefs><li>Plasteel</li></thingDefs>
        </filter>
        <count>25</count>
      </li>
      <li>
        <filter>
          <thingDefs><li>ComponentIndustrial</li></thingDefs>
        </filter>
        <count>15</count>
      </li>
    </ingredients>
    <fixedIngredientFilter>
      <thingDefs>
        <li>Steel</li>
        <li>Plasteel</li>
        <li>ComponentIndustrial</li>
      </thingDefs>
    </fixedIngredientFilter>
    <products>
      <Ammo_KT_MetalStormSlug_AP>300</Ammo_KT_MetalStormSlug_AP>
    </products>
    <workAmount>17000</workAmount>
  </RecipeDef>

</Defs>
