<?xml version="1.0" encoding="utf-8"?>
<Defs>

  <ThingCategoryDef>
    <defName>AmmoKT_PlasmaCell</defName>
    <label>KT Plasma Cell</label>
    <parent>AmmoAdvanced</parent>
    <iconPath>UI/Icons/ThingCategories/CaliberChargeLarge</iconPath>
  </ThingCategoryDef>

  <!-- ==================== AmmoSet ========================== -->

  <CombatExtended.AmmoSetDef>
    <defName>AmmoSet_KT_PlasmaCell</defName>
    <label>KT Plasma Cell</label>
    <ammoTypes>
      <Ammo_KT_PlasmaCell>Bullet_KT_PlasmaCell</Ammo_KT_PlasmaCell>
      <Ammo_KT_PlasmaCell_Focused>Bullet_KT_PlasmaCell_Focused</Ammo_KT_PlasmaCell_Focused>
      <Ammo_KT_PlasmaCell_Overload>Bullet_KT_PlasmaCell_Overload</Ammo_KT_PlasmaCell_Overload>
    </ammoTypes>
  </CombatExtended.AmmoSetDef>

  <!-- ==================== Ammo ========================== -->

  <ThingDef Class="CombatExtended.AmmoDef" Name="KT_PlasmaCellBase" ParentName="SpacerMediumAmmoBase" Abstract="True">
    <description>Plasma energy cell for UF Heavy Industries plasma weapons.</description>
    <statBases>
      <Mass>0.03</Mass>
      <Bulk>0.05</Bulk>
    </statBases>
    <tradeTags>
      <li>CE_AutoEnableTrade</li>
      <li>CE_AutoEnableCrafting_FabricationBench</li>
    </tradeTags>
    <thingCategories>
      <li>AmmoKT_PlasmaCell</li>
    </thingCategories>
    <stackLimit>2500</stackLimit>
  </ThingDef>

  <ThingDef Class="CombatExtended.AmmoDef" ParentName="KT_PlasmaCellBase">
    <defName>Ammo_KT_PlasmaCell</defName>
    <label>KT plasma cell</label>
    <graphicData>
      <texPath>Things/Ammo/Charged/LargeRegular</texPath>
      <graphicClass>Graphic_StackCount</graphicClass>
    </graphicData>
    <ammoClass>KT_Plasma</ammoClass>
  </ThingDef>

  <ThingDef Class="CombatExtended.AmmoDef" ParentName="KT_PlasmaCellBase">
    <defName>Ammo_KT_PlasmaCell_Focused</defName>
    <label>KT plasma cell (Focused)</label>
    <graphicData>
      <texPath>Things/Ammo/Charged/LargeConc</texPath>
      <graphicClass>Graphic_StackCount</graphicClass>
    </graphicData>
    <ammoClass>KT_PlasmaFocused</ammoClass>
    <generateAllowChance>0.15</generateAllowChance>
  </ThingDef>

  <ThingDef Class="CombatExtended.AmmoDef" ParentName="KT_PlasmaCellBase">
    <defName>Ammo_KT_PlasmaCell_Overload</defName>
    <label>KT plasma cell (Overload)</label>
    <graphicData>
      <texPath>Things/Ammo/Charged/LargeIon</texPath>
      <graphicClass>Graphic_StackCount</graphicClass>
    </graphicData>
    <ammoClass>KT_PlasmaOverload</ammoClass>
    <generateAllowChance>0.15</generateAllowChance>
  </ThingDef>

  <!-- ================== Projectiles ================== -->

  <ThingDef Name="BaseKT_PlasmaCellBullet" ParentName="BaseExplosiveBullet" Abstract="true">
    <graphicData>
      <texPath>Things/Projectile/Charged/ChargeShot</texPath>
      <graphicClass>Graphic_Single</graphicClass>
      <shaderType>TransparentPostLight</shaderType>
    </graphicData>
    <projectile Class="CombatExtended.ProjectilePropertiesCE">
      <damageDef>Bullet</damageDef>
    </projectile>
  </ThingDef>

  <ThingDef ParentName="BaseKT_PlasmaCellBullet">
    <defName>Bullet_KT_PlasmaCell</defName>
    <label>KT plasma bolt</label>
    <projectile Class="CombatExtended.ProjectilePropertiesCE">
      <damageAmountBase>36</damageAmountBase>
      <speed>145</speed>
      <secondaryDamage>
        <li>
          <def>EMP</def>
          <amount>15</amount>
        </li>
      </secondaryDamage>
      <armorPenetrationSharp>60</armorPenetrationSharp>
      <armorPenetrationBlunt>220</armorPenetrationBlunt>
    </projectile>
    <comps>
      <li Class="CombatExtended.CompProperties_ExplosiveCE">
        <damageAmountBase>25</damageAmountBase>
        <explosiveDamageType>Bomb</explosiveDamageType>
        <explosiveRadius>1.0</explosiveRadius>
        <explosionSound>MortarBomb_Explode</explosionSound>
        <applyDamageToExplosionCellsNeighbors>true</applyDamageToExplosionCellsNeighbors>
      </li>
    </comps>
  </ThingDef>

  <ThingDef ParentName="BaseKT_PlasmaCellBullet">
    <defName>Bullet_KT_PlasmaCell_Focused</defName>
    <label>KT plasma bolt (Focused)</label>
    <projectile Class="CombatExtended.ProjectilePropertiesCE">
      <damageAmountBase>30</damageAmountBase>
      <speed>155</speed>
      <secondaryDamage>
        <li>
          <def>EMP</def>
          <amount>20</amount>
        </li>
      </secondaryDamage>
      <armorPenetrationSharp>110</armorPenetrationSharp>
      <armorPenetrationBlunt>220</armorPenetrationBlunt>
    </projectile>
  </ThingDef>

  <ThingDef ParentName="BaseKT_PlasmaCellBullet">
    <defName>Bullet_KT_PlasmaCell_Overload</defName>
    <label>KT plasma bolt (Overload)</label>
    <projectile Class="CombatExtended.ProjectilePropertiesCE">
      <damageAmountBase>28</damageAmountBase>
      <speed>135</speed>
      <armorPenetrationSharp>48</armorPenetrationSharp>
      <armorPenetrationBlunt>190</armorPenetrationBlunt>
    </projectile>
    <comps>
      <li Class="CombatExtended.CompProperties_ExplosiveCE">
        <damageAmountBase>35</damageAmountBase>
        <explosiveDamageType>EMP</explosiveDamageType>
        <explosiveRadius>1.5</explosiveRadius>
        <explosionSound>MortarBomb_Explode</explosionSound>
        <applyDamageToExplosionCellsNeighbors>true</applyDamageToExplosionCellsNeighbors>
      </li>
    </comps>
  </ThingDef>

  <!-- ==================== Recipes ========================== -->

  <RecipeDef ParentName="ChargeAmmoRecipeBase">
    <defName>MakeAmmo_KT_PlasmaCell</defName>
    <label>make KT plasma cell x200</label>
    <description>Craft 200 KT plasma cells.</description>
    <jobString>Making KT plasma cells.</jobString>
    <ingredients>
      <li>
        <filter>
          <thingDefs><li>Plasteel</li></thingDefs>
        </filter>
        <count>40</count>
      </li>
      <li>
        <filter>
          <thingDefs><li>ComponentIndustrial</li></thingDefs>
        </filter>
        <count>10</count>
      </li>
      <li>
        <filter>
          <thingDefs><li>ComponentSpacer</li></thingDefs>
        </filter>
        <count>1</count>
      </li>
    </ingredients>
    <fixedIngredientFilter>
      <thingDefs>
        <li>Plasteel</li>
        <li>ComponentIndustrial</li>
        <li>ComponentSpacer</li>
      </thingDefs>
    </fixedIngredientFilter>
    <products>
      <Ammo_KT_PlasmaCell>200</Ammo_KT_PlasmaCell>
    </products>
    <workAmount>16000</workAmount>
  </RecipeDef>

  <RecipeDef ParentName="ChargeAmmoRecipeBase">
    <defName>MakeAmmo_KT_PlasmaCell_Focused</defName>
    <label>make KT plasma cell (Focused) x200</label>
    <description>Craft 200 KT plasma cells (Focused).</description>
    <jobString>Making KT plasma cells (Focused).</jobString>
    <ingredients>
      <li>
        <filter>
          <thingDefs><li>Plasteel</li></thingDefs>
        </filter>
        <count>40</count>
      </li>
      <li>
        <filter>
          <thingDefs><li>ComponentIndustrial</li></thingDefs>
        </filter>
        <count>12</count>
      </li>
      <li>
        <filter>
          <thingDefs><li>ComponentSpacer</li></thingDefs>
        </filter>
        <count>1</count>
      </li>
    </ingredients>
    <fixedIngredientFilter>
      <thingDefs>
        <li>Plasteel</li>
        <li>ComponentIndustrial</li>
        <li>ComponentSpacer</li>
      </thingDefs>
    </fixedIngredientFilter>
    <products>
      <Ammo_KT_PlasmaCell_Focused>200</Ammo_KT_PlasmaCell_Focused>
    </products>
    <workAmount>18000</workAmount>
  </RecipeDef>

  <RecipeDef ParentName="ChargeAmmoRecipeBase">
    <defName>MakeAmmo_KT_PlasmaCell_Overload</defName>
    <label>make KT plasma cell (Overload) x200</label>
    <description>Craft 200 KT plasma cells (Overload).</description>
    <jobString>Making KT plasma cells (Overload).</jobString>
    <ingredients>
      <li>
        <filter>
          <thingDefs><li>Plasteel</li></thingDefs>
        </filter>
        <count>40</count>
      </li>
      <li>
        <filter>
          <thingDefs><li>ComponentIndustrial</li></thingDefs>
        </filter>
        <count>12</count>
      </li>
      <li>
        <filter>
          <thingDefs><li>ComponentSpacer</li></thingDefs>
        </filter>
        <count>2</count>
      </li>
    </ingredients>
    <fixedIngredientFilter>
      <thingDefs>
        <li>Plasteel</li>
        <li>ComponentIndustrial</li>
        <li>ComponentSpacer</li>
      </thingDefs>
    </fixedIngredientFilter>
    <products>
      <Ammo_KT_PlasmaCell_Overload>200</Ammo_KT_PlasmaCell_Overload>
