<?xml version="1.0" encoding="utf-8"?>
<Defs>

  <ThingCategoryDef>
    <defName>AmmoKT_CannonLaserCell</defName>
    <label>KT Cannon Laser Cell</label>
    <parent>AmmoAdvanced</parent>
    <iconPath>UI/Icons/ThingCategories/CaliberChargeLarge</iconPath>
  </ThingCategoryDef>

  <!-- ==================== AmmoSet ========================== -->

  <CombatExtended.AmmoSetDef>
    <defName>AmmoSet_KT_CannonLaserCell</defName>
    <label>KT Cannon Laser Cell</label>
    <ammoTypes>
      <Ammo_KT_CannonLaserCell>Bullet_KT_CannonLaserCell</Ammo_KT_CannonLaserCell>
      <Ammo_KT_CannonLaserCell_Focused>Bullet_KT_CannonLaserCell_Focused</Ammo_KT_CannonLaserCell_Focused>
      <Ammo_KT_CannonLaserCell_Pulse>Bullet_KT_CannonLaserCell_Pulse</Ammo_KT_CannonLaserCell_Pulse>
    </ammoTypes>
  </CombatExtended.AmmoSetDef>

  <!-- ==================== Ammo ========================== -->

  <ThingDef Class="CombatExtended.AmmoDef" Name="KT_CannonLaserCellBase" ParentName="SpacerMediumAmmoBase" Abstract="True">
    <description>Compact energy cell for UF covenant cannon laser weapons.</description>
    <statBases>
      <Mass>0.08</Mass>
      <Bulk>0.12</Bulk>
    </statBases>
    <tradeTags>
      <li>CE_AutoEnableTrade</li>
      <li>CE_AutoEnableCrafting_FabricationBench</li>
    </tradeTags>
    <thingCategories>
      <li>AmmoKT_CannonLaserCell</li>
    </thingCategories>
    <stackLimit>2500</stackLimit>
  </ThingDef>

  <ThingDef Class="CombatExtended.AmmoDef" ParentName="KT_CannonLaserCellBase">
    <defName>Ammo_KT_CannonLaserCell</defName>
    <label>KT cannon laser cell</label>
    <graphicData>
      <texPath>Things/Ammo/Charged/LargeRegular</texPath>
      <graphicClass>Graphic_StackCount</graphicClass>
    </graphicData>
    <ammoClass>KT_Laser</ammoClass>
  </ThingDef>

  <ThingDef Class="CombatExtended.AmmoDef" ParentName="KT_CannonLaserCellBase">
    <defName>Ammo_KT_CannonLaserCell_Focused</defName>
    <label>KT cannon laser cell (Focused)</label>
    <graphicData>
      <texPath>Things/Ammo/Charged/LargeConc</texPath>
      <graphicClass>Graphic_StackCount</graphicClass>
    </graphicData>
    <ammoClass>KT_LaserFocused</ammoClass>
    <generateAllowChance>0.15</generateAllowChance>
  </ThingDef>

  <ThingDef Class="CombatExtended.AmmoDef" ParentName="KT_CannonLaserCellBase">
    <defName>Ammo_KT_CannonLaserCell_Pulse</defName>
    <label>KT cannon laser cell (Pulse)</label>
    <graphicData>
      <texPath>Things/Ammo/Charged/LargeIon</texPath>
      <graphicClass>Graphic_StackCount</graphicClass>
    </graphicData>
    <ammoClass>KT_LaserPulse</ammoClass>
    <generateAllowChance>0.15</generateAllowChance>
  </ThingDef>

  <!-- ================== Projectiles (LaserBeamCE + Harmony mote patch) ================== -->

  <ThingDef Class="CombatExtended.Lasers.LaserBeamDefCE" Name="BaseKT_CannonLaserCellBeam" ParentName="BaseLaserBullet" Abstract="true">
    <projectile Class="CombatExtended.ProjectilePropertiesCE">
      <damageDef>CE_Laser</damageDef>
      <isInstant>true</isInstant>
    </projectile>
    <modExtensions Inherit="False">
      <li Class="UFHeavyIndustries_CE.BeamMoteExtension">
        <beamMoteDef>KT_Beamflashlight_turret_blue</beamMoteDef>
        <beamStartOffset>0</beamStartOffset>
        <impactEffecter>KT_Laserhit_large</impactEffecter>
      </li>
      <li Class="ProjectileImpactFX.EffectProjectileExtension">
        <AutoAssign>false</AutoAssign>
        <CreateTerrainEffects>false</CreateTerrainEffects>
      </li>
    </modExtensions>
  </ThingDef>

  <ThingDef Class="CombatExtended.Lasers.LaserBeamDefCE" ParentName="BaseKT_CannonLaserCellBeam">
    <defName>Bullet_KT_CannonLaserCell</defName>
    <label>KT cannon laser beam</label>
    <projectile Class="CombatExtended.ProjectilePropertiesCE">
      <damageAmountBase>90</damageAmountBase>
      <armorPenetrationSharp>220</armorPenetrationSharp>
      <armorPenetrationBlunt>0.5</armorPenetrationBlunt>
    </projectile>
    <comps>
      <li Class="CombatExtended.CompProperties_ExplosiveCE">
        <damageAmountBase>65</damageAmountBase>
        <explosiveDamageType>KTREDomb</explosiveDamageType>
        <explosiveRadius>2.5</explosiveRadius>
        <explosionSound>MortarBomb_Explode</explosionSound>
        <applyDamageToExplosionCellsNeighbors>true</applyDamageToExplosionCellsNeighbors>
      </li>
    </comps>
  </ThingDef>

  <ThingDef Class="CombatExtended.Lasers.LaserBeamDefCE" ParentName="BaseKT_CannonLaserCellBeam">
    <defName>Bullet_KT_CannonLaserCell_Focused</defName>
    <label>KT cannon laser beam (Focused)</label>
    <projectile Class="CombatExtended.ProjectilePropertiesCE">
      <damageAmountBase>72</damageAmountBase>
      <armorPenetrationSharp>380</armorPenetrationSharp>
      <armorPenetrationBlunt>0.5</armorPenetrationBlunt>
    </projectile>
    <comps>
      <li Class="CombatExtended.CompProperties_ExplosiveCE">
        <damageAmountBase>40</damageAmountBase>
        <explosiveDamageType>KTREDomb</explosiveDamageType>
        <explosiveRadius>1.5</explosiveRadius>
        <explosionSound>MortarBomb_Explode</explosionSound>
        <applyDamageToExplosionCellsNeighbors>true</applyDamageToExplosionCellsNeighbors>
      </li>
    </comps>
  </ThingDef>

  <ThingDef Class="CombatExtended.Lasers.LaserBeamDefCE" ParentName="BaseKT_CannonLaserCellBeam">
    <defName>Bullet_KT_CannonLaserCell_Pulse</defName>
    <label>KT cannon laser beam (Pulse)</label>
    <projectile Class="CombatExtended.ProjectilePropertiesCE">
      <damageAmountBase>95</damageAmountBase>
      <armorPenetrationSharp>170</armorPenetrationSharp>
      <armorPenetrationBlunt>0.5</armorPenetrationBlunt>
    </projectile>
    <comps>
      <li Class="CombatExtended.CompProperties_ExplosiveCE">
        <damageAmountBase>60</damageAmountBase>
        <explosiveDamageType>EMP</explosiveDamageType>
        <explosiveRadius>3.0</explosiveRadius>
        <explosionSound>MortarBomb_Explode</explosionSound>
        <applyDamageToExplosionCellsNeighbors>true</applyDamageToExplosionCellsNeighbors>
      </li>
    </comps>
  </ThingDef>

  <!-- ==================== Recipes ========================== -->

  <RecipeDef ParentName="ChargeAmmoRecipeBase">
    <defName>MakeAmmo_KT_CannonLaserCell</defName>
    <label>make KT cannon laser cell x100</label>
    <description>Craft 100 KT cannon laser cells.</description>
    <jobString>Making KT cannon laser cells.</jobString>
    <ingredients>
      <li>
        <filter>
          <thingDefs><li>Plasteel</li></thingDefs>
        </filter>
        <count>60</count>
      </li>
      <li>
        <filter>
          <thingDefs><li>Steel</li></thingDefs>
        </filter>
        <count>25</count>
      </li>
      <li>
        <filter>
          <thingDefs><li>ComponentIndustrial</li></thingDefs>
        </filter>
        <count>15</count>
      </li>
    </ingredients>
    <fixedIngredientFilter>
      <thingDefs>
        <li>Plasteel</li>
        <li>Steel</li>
        <li>ComponentIndustrial</li>
      </thingDefs>
    </fixedIngredientFilter>
    <products>
      <Ammo_KT_CannonLaserCell>100</Ammo_KT_CannonLaserCell>
    </products>
    <workAmount>22000</workAmount>
  </RecipeDef>

