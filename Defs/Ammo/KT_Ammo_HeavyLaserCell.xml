<?xml version="1.0" encoding="utf-8"?>
<Defs>

  <ThingCategoryDef>
    <defName>AmmoKT_HeavyLaserCell</defName>
    <label>KT Heavy Laser Cell</label>
    <parent>AmmoAdvanced</parent>
    <iconPath>UI/Icons/ThingCategories/CaliberChargeLarge</iconPath>
  </ThingCategoryDef>

  <!-- ==================== AmmoSet ========================== -->

  <CombatExtended.AmmoSetDef>
    <defName>AmmoSet_KT_HeavyLaserCell</defName>
    <label>KT Heavy Laser Cell</label>
    <ammoTypes>
      <Ammo_KT_HeavyLaserCell>Bullet_KT_HeavyLaserCell</Ammo_KT_HeavyLaserCell>
      <Ammo_KT_HeavyLaserCell_Focused>Bullet_KT_HeavyLaserCell_Focused</Ammo_KT_HeavyLaserCell_Focused>
      <Ammo_KT_HeavyLaserCell_Pulse>Bullet_KT_HeavyLaserCell_Pulse</Ammo_KT_HeavyLaserCell_Pulse>
    </ammoTypes>
  </CombatExtended.AmmoSetDef>

  <!-- ==================== Ammo ========================== -->

  <ThingDef Class="CombatExtended.AmmoDef" Name="KT_HeavyLaserCellBase" ParentName="SpacerMediumAmmoBase" Abstract="True">
    <description>Compact energy cell for UF covenant heavy laser weapons.</description>
    <statBases>
      <Mass>0.04</Mass>
      <Bulk>0.06</Bulk>
    </statBases>
    <tradeTags>
      <li>CE_AutoEnableTrade</li>
      <li>CE_AutoEnableCrafting_FabricationBench</li>
    </tradeTags>
    <thingCategories>
      <li>AmmoKT_HeavyLaserCell</li>
    </thingCategories>
    <stackLimit>5000</stackLimit>
  </ThingDef>

  <ThingDef Class="CombatExtended.AmmoDef" ParentName="KT_HeavyLaserCellBase">
    <defName>Ammo_KT_HeavyLaserCell</defName>
    <label>KT heavy laser cell</label>
    <graphicData>
      <texPath>Things/Ammo/Charged/LargeRegular</texPath>
      <graphicClass>Graphic_StackCount</graphicClass>
    </graphicData>
    <ammoClass>Charged</ammoClass>
  </ThingDef>

  <ThingDef Class="CombatExtended.AmmoDef" ParentName="KT_HeavyLaserCellBase">
    <defName>Ammo_KT_HeavyLaserCell_Focused</defName>
    <label>KT heavy laser cell (Focused)</label>
    <graphicData>
      <texPath>Things/Ammo/Charged/LargeConc</texPath>
      <graphicClass>Graphic_StackCount</graphicClass>
    </graphicData>
    <ammoClass>ChargedAP</ammoClass>
    <generateAllowChance>0.15</generateAllowChance>
  </ThingDef>

  <ThingDef Class="CombatExtended.AmmoDef" ParentName="KT_HeavyLaserCellBase">
    <defName>Ammo_KT_HeavyLaserCell_Pulse</defName>
    <label>KT heavy laser cell (Pulse)</label>
    <graphicData>
      <texPath>Things/Ammo/Charged/LargeIon</texPath>
      <graphicClass>Graphic_StackCount</graphicClass>
    </graphicData>
    <ammoClass>Ionized</ammoClass>
    <generateAllowChance>0.15</generateAllowChance>
  </ThingDef>

  <!-- ================== Projectiles ================== -->

  <ThingDef Name="BaseKT_HeavyLaserCellBullet" ParentName="BaseBulletCE" Abstract="true">
    <graphicData>
      <texPath>Things/Projectile/Charged/ChargeShot</texPath>
      <graphicClass>Graphic_Single</graphicClass>
      <shaderType>TransparentPostLight</shaderType>
      <drawSize>(1.3,1.3)</drawSize>
    </graphicData>
    <projectile Class="CombatExtended.ProjectilePropertiesCE">
      <damageDef>Bullet</damageDef>
    </projectile>
  </ThingDef>

  <ThingDef ParentName="BaseKT_HeavyLaserCellBullet">
    <defName>Bullet_KT_HeavyLaserCell</defName>
    <label>KT heavy laser bolt</label>
    <projectile Class="CombatExtended.ProjectilePropertiesCE">
      <damageAmountBase>50</damageAmountBase>
      <speed>185</speed>
      <secondaryDamage>
        <li>
          <def>Bomb_Secondary</def>
          <amount>16</amount>
        </li>
      </secondaryDamage>
      <armorPenetrationSharp>110</armorPenetrationSharp>
      <armorPenetrationBlunt>460</armorPenetrationBlunt>
    </projectile>
  </ThingDef>

  <ThingDef ParentName="BaseKT_HeavyLaserCellBullet">
    <defName>Bullet_KT_HeavyLaserCell_Focused</defName>
    <label>KT heavy laser bolt (Focused)</label>
    <projectile Class="CombatExtended.ProjectilePropertiesCE">
      <damageAmountBase>40</damageAmountBase>
      <speed>195</speed>
      <armorPenetrationSharp>200</armorPenetrationSharp>
      <armorPenetrationBlunt>460</armorPenetrationBlunt>
    </projectile>
  </ThingDef>

  <ThingDef ParentName="BaseKT_HeavyLaserCellBullet">
    <defName>Bullet_KT_HeavyLaserCell_Pulse</defName>
    <label>KT heavy laser bolt (Pulse)</label>
    <projectile Class="CombatExtended.ProjectilePropertiesCE">
      <damageAmountBase>55</damageAmountBase>
      <speed>175</speed>
      <secondaryDamage>
        <li>
          <def>EMP</def>
          <amount>28</amount>
        </li>
      </secondaryDamage>
      <armorPenetrationSharp>85</armorPenetrationSharp>
      <armorPenetrationBlunt>390</armorPenetrationBlunt>
    </projectile>
  </ThingDef>

  <!-- ==================== Recipes ========================== -->

  <RecipeDef ParentName="ChargeAmmoRecipeBase">
    <defName>MakeAmmo_KT_HeavyLaserCell</defName>
    <label>make KT heavy laser cell x300</label>
    <description>Craft 300 KT heavy laser cells.</description>
    <jobString>Making KT heavy laser cells.</jobString>
    <ingredients>
      <li>
        <filter>
          <thingDefs><li>Plasteel</li></thingDefs>
        </filter>
        <count>45</count>
      </li>
      <li>
        <filter>
          <thingDefs><li>Steel</li></thingDefs>
        </filter>
        <count>20</count>
      </li>
      <li>
        <filter>
          <thingDefs><li>ComponentIndustrial</li></thingDefs>
        </filter>
        <count>10</count>
      </li>
    </ingredients>
    <fixedIngredientFilter>
      <thingDefs>
        <li>Plasteel</li>
        <li>Steel</li>
        <li>ComponentIndustrial</li>
      </thingDefs>
    </fixedIngredientFilter>
    <products>
      <Ammo_KT_HeavyLaserCell>300</Ammo_KT_HeavyLaserCell>
    </products>
    <workAmount>16000</workAmount>
  </RecipeDef>

  <RecipeDef ParentName="ChargeAmmoRecipeBase">
    <defName>MakeAmmo_KT_HeavyLaserCell_Focused</defName>
    <label>make KT heavy laser cell (Focused) x300</label>
