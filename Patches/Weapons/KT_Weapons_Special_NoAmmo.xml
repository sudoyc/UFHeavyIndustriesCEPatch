<?xml version="1.0" encoding="utf-8" ?>
<Patch>

	<!-- =============================================================
	     B 类特殊武器 — 保留原始 verb + 原始弹丸，不走 CE 弹道
	     Vanilla-ballistic weapons that keep their original SRA/ECT
	     verbs and projectile classes intact. Only CE stat bases and
	     FireModes are added. NO Verb_ShootCE (would crash on non-CE
	     projectile cast).
	     ============================================================= -->


	<!-- ===== KT_WLL — 巡飞弹发射器 ===== -->
	<!-- 原弹丸: SRA.Projectile_MultiExplosive_NorthArcTrail (追踪弧线+分裂) -->

	<Operation Class="PatchOperationReplace">
		<xpath>Defs/ThingDef[defName="KT_WLL"]/tools</xpath>
		<value>
			<tools>
				<li Class="CombatExtended.ToolCE">
					<label>stock</label>
					<capacities>
						<li>Blunt</li>
					</capacities>
					<power>10</power>
					<cooldownTime>1.85</cooldownTime>
					<armorPenetrationBlunt>5</armorPenetrationBlunt>
					<linkedBodyPartsGroup>Stock</linkedBodyPartsGroup>
				</li>
			</tools>
		</value>
	</Operation>

	<Operation Class="PatchOperationReplace">
		<xpath>Defs/ThingDef[defName="KT_WLL"]/statBases</xpath>
		<value>
			<statBases>
				<WorkToMake>75000</WorkToMake>
				<Mass>3.0</Mass>
				<RangedWeapon_Cooldown>1.5</RangedWeapon_Cooldown>
				<SightsEfficiency>1.0</SightsEfficiency>
				<ShotSpread>0.08</ShotSpread>
				<SwayFactor>1.2</SwayFactor>
				<Bulk>6.0</Bulk>
			</statBases>
		</value>
	</Operation>

	<Operation Class="PatchOperationAdd">
		<xpath>Defs/ThingDef[defName="KT_WLL"]/comps</xpath>
		<value>
			<li Class="CombatExtended.CompProperties_FireModes">
				<aiAimMode>AimedShot</aiAimMode>
			</li>
		</value>
	</Operation>


