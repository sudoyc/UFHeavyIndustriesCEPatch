	<!-- ===== KT_Analnail — 达因斯尼夫 ===== -->
	<!-- 原弹丸: ECT.Projectile_HeavyArmourPiercer (贯穿掠射+击退+闪电) -->
	<!-- 原 verb: Verb_ShootOneUse (一次性武器), range=200, requireLineOfSight=false -->

