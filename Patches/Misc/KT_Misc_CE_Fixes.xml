<?xml version="1.0" encoding="utf-8"?>
<Patch>

  <!-- Fix: KT_Powerarmor forcedMissRadius causes CE config error -->
  <Operation Class="PatchOperationRemove">
    <xpath>Defs/ThingDef[defName="KT_Powerarmor"]/verbs/li[defaultProjectile="Proj_120mm"]/forcedMissRadius</xpath>
  </Operation>
  <Operation Class="PatchOperationRemove">
    <xpath>Defs/ThingDef[defName="KT_Powerarmor"]/verbs/li[defaultProjectile="Proj_plasmabullet"]/forcedMissRadius</xpath>
  </Operation>

  <!-- Fix: KT_armament_Trader references vanilla shells that CE marks non-tradeable -->
  <Operation Class="PatchOperationRemove">
    <xpath>Defs/TraderKindDef[defName="KT_armament_Trader"]/stockGenerators/li[@Class="StockGenerator_SingleDef"][thingDef="Shell_HighExplosive"]</xpath>
  </Operation>
  <Operation Class="PatchOperationRemove">
    <xpath>Defs/TraderKindDef[defName="KT_armament_Trader"]/stockGenerators/li[@Class="StockGenerator_SingleDef"][thingDef="Shell_Incendiary"]</xpath>
  </Operation>
  <Operation Class="PatchOperationRemove">
    <xpath>Defs/TraderKindDef[defName="KT_armament_Trader"]/stockGenerators/li[@Class="StockGenerator_SingleDef"][thingDef="Shell_EMP"]</xpath>
  </Operation>
  <Operation Class="PatchOperationRemove">
    <xpath>Defs/TraderKindDef[defName="KT_armament_Trader"]/stockGenerators/li[@Class="StockGenerator_SingleDef"][thingDef="Shell_Smoke"]</xpath>
  </Operation>
  <Operation Class="PatchOperationRemove">
    <xpath>Defs/TraderKindDef[defName="KT_armament_Trader"]/stockGenerators/li[@Class="StockGenerator_SingleDef"][thingDef="Shell_Firefoam"]</xpath>
  </Operation>
  <Operation Class="PatchOperationRemove">
    <xpath>Defs/TraderKindDef[defName="KT_armament_Trader"]/stockGenerators/li[@Class="StockGenerator_SingleDef"][thingDef="Shell_Toxic"]</xpath>
  </Operation>

</Patch>
